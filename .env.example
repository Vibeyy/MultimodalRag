# OpenAI API Configuration (Required)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_RATE_LIMIT=60

# Qdrant Configuration - CHOOSE ONE METHOD:

# METHOD 1: CLOUD DEPLOYMENT (Recommended - Free 1GB tier available)
# Sign up at https://cloud.qdrant.io/ and create a cluster
# Uncomment these lines and fill with your values:
QDRANT_URL=https://YOUR-CLUSTER-ID.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=YOUR_QDRANT_API_KEY_HERE

# METHOD 2: LOCAL DEPLOYMENT (Docker/Local instance)
# Comment out QDRANT_URL and QDRANT_API_KEY above, use these instead:
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Collection name (used by both local and cloud)
QDRANT_COLLECTION_NAME=multimodal_rag

# Firebase Configuration (Required for Authentication & Chat History)
# Get credentials from Firebase Console: https://console.firebase.google.com/
# 1. Go to Project Settings → Service Accounts → Generate new private key
# 2. Copy values from the downloaded JSON file
# 3. For Web API Key: Project Settings → General → Web API Key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_WEB_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Generation Settings
# Allow answering from general knowledge when retrieval finds nothing (like ChatGPT)
ALLOW_GENERAL_KNOWLEDGE=true
# Minimum similarity score to consider retrieval results useful (0.0-1.0)
RETRIEVAL_CONFIDENCE_THRESHOLD=0.3

# Application Configuration
MAX_RETRIES=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=10

# PDF Processing Settings (for large documents/books)
PDF_MAX_PAGES=100              # Max pages to process per PDF (prevents huge costs)
PDF_USE_VISION=true            # Use Vision API (set false for text-only PDFs to save costs)
PDF_VISION_THRESHOLD=100       # Use Vision if page has < this many chars (smart fallback)

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
